# Copy this file to secrets/sftp.env and fill in SFTP_PASS.
# secrets/sftp.env is gitignored — never commit real credentials.
#
# Legacy format also supported: same folder, name it sftp.txt with lines:
#   host: x.x.x.x
#   user: myuser
#   pass: secret

SFTP_HOST=
SFTP_USER=
SFTP_PASS=
SFTP_PORT=22

# Laravel root under SFTP home. Leave empty if artisan lives next to public_html (same as home).
# Use koon-hosting if you upload the zip bundle to ~/koon-hosting (see scripts/HOSTING.txt).
SFTP_APP_DIR=
SFTP_PUBLIC_DIR=public_html

# Optional: HTTPS origin for scripts/sftp_one_shot_deploy_database.py (default https://koon.edu.sa)
# ONE_SHOT_PUBLIC_URL=https://koon.edu.sa

# Optional: set if auto-detection is wrong
# SFTP_REMOTE_HOME=/home/youruser
