APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8001
# Optional: host/port shown by repo scripts.ps1 (when APP_URL has no port, default is http://127.0.0.1:8001)
# ARTISAN_SERVE_HOST=127.0.0.1
# ARTISAN_SERVE_PORT=8001

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
# Local: log deprecations to storage/logs/laravel.log. Production: use null or single + LOG_LEVEL=error.
LOG_DEPRECATIONS_CHANNEL=single
LOG_DEPRECATIONS_TRACE=false
LOG_LEVEL=debug
# Local only: log slow SQL (see AppServiceProvider). Disable with LOG_QUERIES=false.
LOG_QUERIES=false
LOG_SLOW_QUERY_MS=250

# ---------------------------------------------------------------------------
# Database — local: MySQL (XAMPP / phpMyAdmin), same engine as production
# ---------------------------------------------------------------------------
# 1) Start MySQL in XAMPP (or: docker compose up -d mysql from repo root).
# 2) Create a database (phpMyAdmin → SQL, or run scripts/mysql-local-xampp.sql).
# 3) Match DB_* below. XAMPP default is often root with empty password.
#
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=koon_local
DB_USERNAME=root
DB_PASSWORD=

# --- Docker MySQL (repo root: docker compose up -d mysql) — alternative ---
# DB_DATABASE=koon
# DB_USERNAME=koon
# DB_PASSWORD=koon

# --- SQLite-only dev (no MySQL) ---
# DB_CONNECTION=sqlite
# DB_DATABASE=database/database.sqlite

# Production: copy backend/.env.production.example → .env on the server (never upload your PC's .env).
# cPanel: if "Connection refused", try DB_HOST=127.0.0.1 instead of localhost.
# Until MySQL works on the host, keep CACHE_STORE=file, SESSION_DRIVER=file, QUEUE_CONNECTION=sync.

# Defaults match config/*.php (file + sync) so production survives MySQL misconfig.
# After DB_* works, you may switch to database for cache/session/queue if you want.
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Local admin (React /api auth) — override in production
ADMIN_EMAIL=admin@koon.edu.sa
ADMIN_PASSWORD=123
ADMIN_NAME="KOON Admin"

# Optional production recovery: when DEFAULT_ADMIN_PASSWORD is non-empty, AdminUserSeeder
# resets that password for DEFAULT_ADMIN_EMAIL, ADMIN_EMAIL, and admin@koon.edu.sa.
# Passwords with $ break plain .env parsing — prefer base64 (UTF-8) or scripts/sftp_one_shot_set_admin_password.py
# DEFAULT_ADMIN_EMAIL=admin@koon.edu.sa
# DEFAULT_ADMIN_PASSWORD=
# DEFAULT_ADMIN_PASSWORD_BASE64=   # echo -n 'yourpass' | base64  (one line, no quotes)

VITE_APP_NAME="${APP_NAME}"
