APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
# Optional: host/port shown by repo scripts.ps1 (when APP_URL has no port, default is http://127.0.0.1:8000)
# ARTISAN_SERVE_HOST=127.0.0.1
# ARTISAN_SERVE_PORT=8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database: SQLite when APP_ENV is not production unless DB_CONNECTION is set
# (see config/database.php — production defaults to MySQL).
DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

# --- MySQL (e.g. docker compose up -d mysql from repo root) ---
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=koon
# DB_USERNAME=koon
# DB_PASSWORD=koon

# --- Production MySQL (use real values only in server .env) ---
# APP_ENV=production
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=your_database
# DB_USERNAME=your_user
# DB_PASSWORD=your_password
#
# cPanel / shared hosting: if you see HTTP 500 and laravel.log shows "Connection refused"
# to mysql on localhost, try DB_HOST=127.0.0.1 (or the socket host your host documents).
# Until MySQL works, avoid database-backed cache/session (every request hits the DB):
#   CACHE_STORE=file
#   SESSION_DRIVER=file
#   QUEUE_CONNECTION=sync

# Defaults match config/*.php (file + sync) so production survives MySQL misconfig.
# After DB_* works, you may switch to database for cache/session/queue if you want.
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Local admin (React /api auth) — override in production
ADMIN_EMAIL=admin@koon.edu.sa
ADMIN_PASSWORD=123
ADMIN_NAME="KOON Admin"

# Optional production recovery: when DEFAULT_ADMIN_PASSWORD is non-empty, AdminUserSeeder
# resets that password for DEFAULT_ADMIN_EMAIL, ADMIN_EMAIL, and admin@koon.edu.sa.
# Passwords with $ break plain .env parsing — prefer base64 (UTF-8) or scripts/sftp_one_shot_set_admin_password.py
# DEFAULT_ADMIN_EMAIL=admin@koon.edu.sa
# DEFAULT_ADMIN_PASSWORD=
# DEFAULT_ADMIN_PASSWORD_BASE64=   # echo -n 'yourpass' | base64  (one line, no quotes)

VITE_APP_NAME="${APP_NAME}"
